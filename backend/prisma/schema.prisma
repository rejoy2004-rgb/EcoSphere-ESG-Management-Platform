datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  ESG_MANAGER
  DEPARTMENT_HEAD
  EMPLOYEE
}

model User {
  id                 String       @id @default(uuid())
  name               String
  email              String       @unique
  passwordHash       String
  role               Role         @default(EMPLOYEE)
  departmentId       String?
  department         Department?  @relation("UserDepartment", fields: [departmentId], references: [id], onDelete: SetNull)
  managedDepartments Department[] @relation("DepartmentHead")
  pointsBalance      Int          @default(0)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model Department {
  id                 String       @id @default(uuid())
  name               String
  code               String       @unique
  headId             String?
  head               User?        @relation("DepartmentHead", fields: [headId], references: [id], onDelete: SetNull)
  parentDepartmentId String?
  parentDepartment   Department?  @relation("DepartmentHierarchy", fields: [parentDepartmentId], references: [id], onDelete: Cascade)
  subDepartments     Department[] @relation("DepartmentHierarchy")
  employeeCount      Int          @default(0)
  status             String       @default("ACTIVE")
  employees          User[]       @relation("UserDepartment")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
}

model HealthCheck {
  id        Int      @id @default(autoincrement())
  status    String
  checkedAt DateTime @default(now())
}
